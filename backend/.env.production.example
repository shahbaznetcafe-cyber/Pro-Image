APP_ENV=production
ALLOWED_ORIGINS=https://your-domain.com
SBZ_API_KEYS=replace-with-a-long-random-api-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key
# Long random value; must match private.seller_release_secret in Supabase.
# Authorises quota refunds for strict-quality blocks that deliver nothing.
SELLER_RELEASE_SECRET=replace-with-a-long-random-secret
# Per-IP requests/minute for public unauthenticated endpoints
# (analyze-images, preview-seller-studio). 0 disables. Per worker process.
PUBLIC_RATE_LIMIT_PER_MINUTE=20
# Async batch queue. Required for /tools/batch-jobs. Point the web and arq
# worker at the same Redis and the same JOBS_OUTPUT_DIR (shared volume).
REDIS_URL=redis://redis:6379/0
JOBS_OUTPUT_DIR=/data/jobs
JOB_RETENTION_SECONDS=3600
# Observability. JSON logs go to stdout at LOG_LEVEL; set SENTRY_DSN to enable
# error tracking (sentry-sdk is already a dependency).
LOG_LEVEL=INFO
SENTRY_DSN=
