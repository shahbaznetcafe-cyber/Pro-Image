APP_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
SBZ_API_KEYS=dev-api-key-change-me
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key
# Must match private.seller_release_secret in Supabase. Enables quota refunds
# when a strict-quality block produces no deliverable. Leave empty to disable.
SELLER_RELEASE_SECRET=
# Async batch queue (leave empty to disable and use the inline batch endpoint)
REDIS_URL=
JOBS_OUTPUT_DIR=
JOB_RETENTION_SECONDS=3600
# Observability
LOG_LEVEL=INFO
SENTRY_DSN=
